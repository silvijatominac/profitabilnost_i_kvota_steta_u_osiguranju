        "import pandas as pd\n",
        "import numpy as np\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "# 1. Postavljanje seeda za reproduktivnost\n",
        "np.random.seed(42)\n",
        "n_rows = 10_000\n",
        "start_date = datetime(2025, 1, 1)\n",
        "\n",
        "# 2. Generiranje osnovnih podataka o policama\n",
        "policy_id = np.arange(1, n_rows + 1)\n",
        "\n",
        "channels = ['IPM', 'Web', 'Banka', 'Broker']\n",
        "channel_probs = [0.4, 0.3, 0.1, 0.2]\n",
        "policy_channel = np.random.choice(channels, n_rows, p=channel_probs)\n",
        "\n",
        "regions = ['Zagreb', 'Slavonija', 'Dalmacija', 'Istra i Kvarner']\n",
        "regions_probs = [0.4, 0.3, 0.2, 0.1]\n",
        "policy_region = np.random.choice(regions, n_rows, p=regions_probs)\n",
        "\n",
        "age = np.random.randint(18, 85, n_rows)\n",
        "\n",
        "# 3. Generiranje iznosa zarađene premije\n",
        "base_premium = 200\n",
        "premium = base_premium + np.random.normal(50, 15, n_rows)\n",
        "premium = np.where(policy_region == 'Zagreb', premium * 1.1, premium)\n",
        "\n",
        "# 4. Generiranje šteta (Poissonova distribucija za više šteta po polici)\n",
        "policy_data = []\n",
        "claims_data = []\n",
        "\n",
        "for i in range(n_rows):\n",
        "    # Bazna očekivana učestalost šteta\n",
        "    p_claim = 0.10\n",
        "    if policy_channel[i] == 'Broker':\n",
        "        p_claim += 0.05\n",
        "    if policy_region[i] == 'Dalmacija':\n",
        "        p_claim += 0.08\n",
        "    if age[i] < 25:\n",
        "        p_claim += 0.05\n",
        "\n",
        "    # Poissonova distribucija generira npr. 0, 1, 2 ili 3 štete na temelju p_claim\n",
        "    num_claims = np.random.poisson(p_claim)\n",
        "    \n",
        "    total_claims = 0\n",
        "    total_amount = 0.0\n",
        "    \n",
        "    if num_claims > 0:\n",
        "        for _ in range(num_claims):\n",
        "            total_claims += 1\n",
        "            \n",
        "            # Računanje iznosa svake pojedinačne štete\n",
        "            amt = np.random.exponential(scale=1200) + 100\n",
        "            if np.random.rand() < 0.01:\n",
        "                amt += np.random.uniform(5000, 15000)\n",
        "            if age[i] < 25:\n",
        "                amt += np.random.uniform(500, 2000)\n",
        "                \n",
        "            total_amount += amt\n",
        "            \n",
        "            # Generiranje datuma štete\n",
        "            if policy_region[i] == 'Dalmacija' and np.random.rand() < 0.70:\n",
        "                day_offset = np.random.randint(151, 274) # Lipanj - Rujan\n",
        "            else:\n",
        "                day_offset = np.random.randint(0, 365)\n",
        "                \n",
        "            claim_date = start_date + timedelta(days=int(day_offset))\n",
        "            \n",
        "            # Spremam pojedinačnu štetu u bazu šteta\n",
        "            claims_data.append({\n",
        "                'Broj_police': policy_id[i],\n",
        "                'Datum_štete': claim_date.strftime('%Y-%m-%d'),\n",
        "                'Iznos_pojedinačne_štete': np.round(amt, 2)\n",
        "            })\n",
        "            \n",
        "    # Spremam ukupne podatke o polici\n",
        "    policy_data.append({\n",
        "        'Broj_police': policy_id[i],\n",
        "        'Starost': age[i],\n",
        "        'Kanal_prodaje': policy_channel[i],\n",
        "        'Regija': policy_region[i],\n",
        "        'Premija': np.round(premium[i], 2),\n",
        "        'Broj_šteta': total_claims,\n",
        "        'Iznos_štete': np.round(total_amount, 2)\n",
        "    })\n",
        "\n",
        "# 5. Kreiranje DataFrameova\n",
        "df = pd.DataFrame(policy_data)\n",
        "df_stete = pd.DataFrame(claims_data)\n",
        "\n",
        "# 6. Izvoz u CSV datoteke\n",
        "df.to_csv('osiguranje_dataset.csv', index=False)\n",
        "df_stete.to_csv('pojedinacne_stete.csv', index=False)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 14,
      "metadata": {},
      "outputs": [],
      "source": [
        "# IZRAČUN KVOTE ŠTETA, FREKVENCIJE ŠTETA I PROSJEČAN TROŠAK ŠTETE #\n",
        "\n",
        "kvota_šteta = df[\"Iznos_štete\"].sum()/df[\"Premija\"].sum()\n",
        "\n",
        "# 1. Izračun po regijama\n",
        "df_regija = df.groupby('Regija', observed=False).agg(\n",
        "    Broj_polica=('Broj_police', 'count'),\n",
        "    Broj_prijavljenih_šteta=('Broj_šteta', 'sum'),\n",
        "    Ukupna_premija=('Premija', 'sum'),\n",
        "    Ukupne_štete=('Iznos_štete', 'sum')\n",
        ").reset_index()\n",
        "\n",
        "df_regija['Kvote_šteta'] = df_regija['Ukupne_štete'] / df_regija['Ukupna_premija']\n",
        "df_regija['Frekvencije_šteta'] = df_regija['Broj_prijavljenih_šteta'] / df_regija['Broj_polica']\n",
        "df_regija['Prosječan_trošak_štete'] = df_regija['Ukupne_štete'] / df_regija['Broj_prijavljenih_šteta']\n",
        "df_regija['Tehnički_rezultat'] = df_regija['Ukupna_premija'] - df_regija['Ukupne_štete']\n",
        "\n",
        "# 2. Izračun po kanalima prodaje\n",
        "df_kanal = df.groupby('Kanal_prodaje', observed=False).agg(\n",
        "    Broj_polica=('Broj_police', 'count'),\n",
        "    Broj_prijavljenih_šteta=('Broj_šteta', 'sum'),\n",
        "    Ukupna_premija=('Premija', 'sum'),\n",
        "    Ukupne_štete=('Iznos_štete', 'sum')\n",
        ").reset_index()\n",
        "\n",
        "df_kanal['Kvote_šteta'] = df_kanal['Ukupne_štete'] / df_kanal['Ukupna_premija']\n",
        "df_kanal['Frekvencije_šteta'] = df_kanal['Broj_prijavljenih_šteta'] / df_kanal['Broj_polica']\n",
        "df_kanal['Prosječan_trošak_štete'] = df_kanal['Ukupne_štete'] / df_kanal['Broj_prijavljenih_šteta']\n",
        "df_kanal['Tehnički_rezultat'] = df_kanal['Ukupna_premija'] - df_kanal['Ukupne_štete']\n",
        "\n",
        "# 3. Izračun po starosti vozača\n",
        "# vozače dijelim u skupine po kategorijama starosti\n",
        "bins = [17, 25, 45, 65, 85]\n",
        "labels = ['Mladi', 'Odrasla dob', 'Srednja dob', 'Stari']\n",
        "\n",
        "# Stvaram novi stupac za kategorije starosti (dobnim skupinama)\n",
        "df['Dobna_skupina'] = pd.cut(df['Starost'], bins=bins, labels=labels)\n",
        "df_starost = df.groupby('Dobna_skupina', observed=False).agg(\n",
        "    Broj_polica=('Broj_police', 'count'),\n",
        "    Broj_prijavljenih_šteta=('Broj_šteta', 'sum'),\n",
        "    Ukupna_premija=('Premija', 'sum'),\n",
        "    Ukupne_štete=('Iznos_štete', 'sum')\n",
        ").reset_index()\n",
        "\n",
        "df_starost['Kvote_šteta'] = df_starost['Ukupne_štete'] / df_starost['Ukupna_premija']\n",
        "df_starost['Frekvencije_šteta'] = df_starost['Broj_prijavljenih_šteta'] / df_starost['Broj_polica']\n",
        "df_starost['Prosječan_trošak_štete'] = df_starost['Ukupne_štete'] / df_starost['Broj_prijavljenih_šteta']\n",
        "df_starost['Tehnički_rezultat'] = df_starost['Ukupna_premija'] - df_starost['Ukupne_štete']"
      ]
    },
