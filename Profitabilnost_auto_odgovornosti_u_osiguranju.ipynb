        "# KREIRANJE PDF DATOTEKE #\n",
        "\n",
        "from reportlab.lib.pagesizes import landscape, letter\n",
        "from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle\n",
        "from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle\n",
        "from reportlab.lib import colors\n",
        "from reportlab.pdfbase import pdfmetrics\n",
        "from reportlab.pdfbase.ttfonts import TTFont\n",
        "\n",
        "pdfmetrics.registerFont(TTFont('CalibriCustom', 'calibri.ttf'))\n",
        "pdfmetrics.registerFont(TTFont('CalibriCustom-Bold', 'calibrib.ttf'))\n",
        "pdfmetrics.registerFont(TTFont('CalibriCustom-Italic', 'calibrii.ttf'))\n",
        "pdfmetrics.registerFontFamily('CalibriCustom', normal='CalibriCustom', bold='CalibriCustom-Bold', italic='CalibriCustom-Italic')\n",
        "\n",
        "def create_pdf_report():\n",
        "    pdf_filename = \"Izvjestaj_profitabilnost.pdf\"\n",
        "    doc = SimpleDocTemplate(pdf_filename, pagesize=landscape(letter),\n",
        "                            rightMargin=20, leftMargin=20, topMargin=20, bottomMargin=20)\n",
        "    story = []\n",
        "\n",
        "    # Stilovi\n",
        "    styles = getSampleStyleSheet()\n",
        "\n",
        "    # Prilagođeni stilovi\n",
        "    naslov_stil = ParagraphStyle(\n",
        "        'GlavniNaslov',\n",
        "        parent=styles['Heading1'],\n",
        "        fontName='CalibriCustom',\n",
        "        fontSize=18,\n",
        "        textColor=colors.HexColor(\"#1B365D\"),\n",
        "        spaceAfter=12,\n",
        "        alignment=1\n",
        "    )\n",
        "\n",
        "    podnaslov_stil = ParagraphStyle(\n",
        "        'Podnaslov',\n",
        "        parent=styles['Heading2'],\n",
        "        fontName='CalibriCustom',\n",
        "        fontSize=14,\n",
        "        textColor=colors.HexColor(\"#2E5B88\"),\n",
        "        spaceBefore=12,\n",
        "        spaceAfter=6\n",
        "    )\n",
        "\n",
        "    tekst_stil = ParagraphStyle(\n",
        "        'ObicniTekst',\n",
        "        parent=styles['BodyText'],\n",
        "        fontName='CalibriCustom',\n",
        "        fontSize=10,\n",
        "        leading=14,\n",
        "        spaceAfter=8\n",
        "    )\n",
        "\n",
        "    # 1. UVOD I METODOLOGIJA\n",
        "    story.append(Paragraph(\"Profitabilnost linije proizvoda \\\"Auto-odgovornost\\\"\", naslov_stil))\n",
        "    story.append(Spacer(1, 10))\n",
        "    story.append(Paragraph(\"<b>Uvod i metodologija</b>\", podnaslov_stil))\n",
        "    story.append(Paragraph(\n",
        "        \"Ovaj izvještaj sadrži analizu profitabilnosti osiguravajućeg društva u liniji proizvoda \\\"Auto-odgovornost\\\" na bazi od 10.000 simuliranih polica.<br/>\"\n",
        "        \"Glavni fokus je izračun profitabilnosti kroz usporedbu zarađene premije i isplaćenih šteta.\", tekst_stil\n",
        "    ))\n",
        "    story.append(Spacer(1, 10))\n",
        "\n",
        "    # Pomoćna funkcija za pretvaranje DataFrame-a u ReportLab tablicu\n",
        "    def df_to_pdf_table(dataframe, header_labels):\n",
        "        # Pretvaranje brojeva u postotke i valutu radi ljepšeg prikaza\n",
        "        df_display = dataframe.copy()\n",
        "        for col in df_display.columns:\n",
        "            if any(x in col.lower() for x in ['ukup', 'trošak', 'rezultat']):\n",
        "                # Format novca: 1.234,56 €\n",
        "                df_display[col] = df_display[col].apply(lambda x: f\"{x:,.2f} €\".replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \".\"))\n",
        "            elif any(x in col.lower() for x in ['kvot', 'frekvenc']):\n",
        "                # Format postotka: 12,3%\n",
        "                df_display[col] = df_display[col].apply(lambda x: f\"{x*100:.1f}%\")\n",
        "            elif any(x in col.lower() for x in ['broj']):\n",
        "                # Cijeli brojevi bez decimala\n",
        "                df_display[col] = df_display[col].apply(lambda x: f\"{x:,.0f}\".replace(\",\", \".\"))\n",
        "\n",
        "        # Sastavljanje podataka (zaglavlje + redovi)\n",
        "        data = [header_labels] + df_display.values.tolist()\n",
        "\n",
        "        t = Table(data)\n",
        "        t.setStyle(TableStyle([\n",
        "            ('BACKGROUND', (0, 0), (-1, 0), colors.HexColor(\"#1B365D\")),\n",
        "            ('TEXTCOLOR', (0, 0), (-1, 0), colors.whitesmoke),\n",
        "            ('ALIGN', (0, 0), (-1, -1), 'CENTER'),\n",
        "            ('ALIGN', (1, 1), (-1, -1), 'RIGHT'),\n",
        "            ('FONTNAME', (0, 0), (-1, 0), 'CalibriCustom'),\n",
        "            ('FONTNAME', (0, 1), (-1, -1), 'CalibriCustom'),\n",
        "            ('FONTSIZE', (0, 0), (-1, 0), 9),\n",
        "            ('FONTSIZE', (0, 1), (-1, -1), 8),\n",
        "            ('BOTTOMPADDING', (0, 0), (-1, 0), 6),\n",
        "            ('TOPPADDING', (0, 0), (-1, 0), 6),\n",
        "            ('BACKGROUND', (0, 1), (-1, -1), colors.HexColor(\"#F2F4F7\")),\n",
